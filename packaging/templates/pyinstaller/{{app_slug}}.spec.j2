# PyInstaller onedir spec for {{ display_name }}. GENERATED by `dough bake` from
# [tool.dough.metadata] — edit the template, never this file. One spec for both
# frozen targets:
#   Linux   → the onedir the .deb stages under /opt/{{ app_slug }} + the AppImage wraps.
#   Windows → the windowed onedir Inno Setup / the portable zip wrap, with the
#             generated .ico + version_info.txt (built by release.yml before this).
#
# Run from the repo root:  pyinstaller packaging/pyinstaller/{{ app_slug }}.spec --noconfirm
import os
import sys

from PyInstaller.utils.hooks import collect_data_files

# SPECPATH is the spec's own directory (packaging/pyinstaller); ROOT is the repo.
HERE = SPECPATH
ROOT = os.path.dirname(os.path.dirname(HERE))

# Ship the brand SVG (resolved at runtime via importlib.resources) + the license.
datas = collect_data_files("{{ app_slug }}", includes=["assets/*.svg"])
datas += [(os.path.join(ROOT, "LICENSE"), ".")]

a = Analysis(
    [os.path.join(HERE, "launch.py")],
    pathex=[ROOT],
    binaries=[],
    datas=datas,
    hiddenimports=[],
    hookspath=[],
    runtime_hooks=[],
    excludes=[
        # Heavy Qt modules the chrome never imports — keeps the bundle lean. A
        # fork that uses any of these removes it from this list.
        "tkinter",
        "PySide6.QtWebEngineCore",
        "PySide6.QtWebEngineWidgets",
        "PySide6.QtQuick",
        "PySide6.QtQml",
        "PySide6.Qt3DCore",
        "PySide6.QtCharts",
        "PySide6.QtDataVisualization",
        "PySide6.QtPdf",
    ],
    noarchive=False,
)
pyz = PYZ(a.pure)

# Windows: stamp the generated icon + VSVersionInfo when release.yml produced them.
exe_kwargs = {}
if sys.platform == "win32":
    _ico = os.path.join(ROOT, "packaging", "windows", "{{ app_slug }}.ico")
    if os.path.exists(_ico):
        exe_kwargs["icon"] = _ico
    _ver = os.path.join(ROOT, "packaging", "windows", "version_info.txt")
    if os.path.exists(_ver):
        exe_kwargs["version"] = _ver

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name="{{ app_slug }}",
    debug=False,
    strip=False,
    upx=False,
    console=False,  # GUI app — no console window on Windows
    **exe_kwargs,
)
coll = COLLECT(
    exe,
    a.binaries,
    a.datas,
    strip=False,
    upx=False,
    name="{{ app_slug }}",
)
