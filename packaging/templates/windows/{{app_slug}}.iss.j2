; Inno Setup script for {{ display_name }} — wraps the PyInstaller onedir bundle
; (dist/{{ app_slug }}) into the Windows installer published on GitHub Releases.
; GENERATED by `dough bake` — edit the template, never this file.
;
; Build (CI: release.yml; iscc ships on the windows-latest runner):
;   iscc /DAppVersion=0.1.0 packaging\windows\{{ app_slug }}.iss
;
; Per-user install (no admin prompt) — what winget expects from new submissions.
{% set appid = '{' ~ '{' ~ store_secrets_of_record.inno_appid_guid ~ '}' -%}

#ifndef AppVersion
  #define AppVersion "0.0.0"
#endif

[Setup]
; Immutable AppId (docs/BAKING.md §9) — never change it.
AppId={{ appid }}
AppName={{ display_name }}
AppVersion={{ "{#AppVersion}" }}
AppPublisher={{ publisher_display_name }}
AppPublisherURL={{ homepage_url }}
AppSupportURL={{ issues_url }}
AppUpdatesURL={{ releases_url }}
DefaultDirName={autopf}\{{ app_slug }}
DefaultGroupName={{ display_name }}
PrivilegesRequired=lowest
PrivilegesRequiredOverridesAllowed=dialog
OutputBaseFilename={{ app_slug }}-{{ "{#AppVersion}" }}-windows-x64-setup
OutputDir=..\..\dist
; The .ico is generated from the brand SVG by release.yml; degrade to the default
; installer icon when it's absent (a local build without the rasterize step).
#if FileExists(AddBackslash(SourcePath) + "{{ app_slug }}.ico")
SetupIconFile={{ app_slug }}.ico
#endif
UninstallDisplayIcon={app}\{{ app_slug }}.exe
Compression=lzma2
SolidCompression=yes
WizardStyle=modern
ArchitecturesAllowed=x64compatible
ArchitecturesInstallIn64BitMode=x64compatible
LicenseFile=..\..\LICENSE

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[Files]
; The whole PyInstaller onedir output.
Source: "..\..\dist\{{ app_slug }}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\{{ display_name }}"; Filename: "{app}\{{ app_slug }}.exe"
Name: "{group}\{cm:UninstallProgram,{{ display_name }}}"; Filename: "{uninstallexe}"
Name: "{autodesktop}\{{ display_name }}"; Filename: "{app}\{{ app_slug }}.exe"; Tasks: desktopicon

[Run]
Filename: "{app}\{{ app_slug }}.exe"; Description: "{cm:LaunchProgram,{{ display_name }}}"; Flags: nowait postinstall skipifsilent
