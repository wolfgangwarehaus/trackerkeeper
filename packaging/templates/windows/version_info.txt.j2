# VSVersionInfo for {{ display_name }} — the Windows file/product metadata the
# frozen .exe carries (Properties → Details). GENERATED by `dough bake`; the
# version is injected at release time (committed form is 0.0.0). This is the
# VSVersionInfo PyInstaller specs commonly omit (docs/BAKING.md §5). filevers is a
# pre-validated 4-int tuple (dough.bake) so a pre-release tag can't emit a non-int.
VSVersionInfo(
  ffi=FixedFileInfo(
    filevers={{ filevers | default((0, 0, 0, 0)) }},
    prodvers={{ filevers | default((0, 0, 0, 0)) }},
    mask=0x3f,
    flags=0x0,
    OS=0x40004,
    fileType=0x1,
    subtype=0x0,
    date=(0, 0),
  ),
  kids=[
    StringFileInfo([
      StringTable(
        '040904B0',
        [
          StringStruct('CompanyName', '{{ publisher_display_name }}'),
          StringStruct('FileDescription', '{{ summary }}'),
          StringStruct('FileVersion', '{{ release_version | default('0.0.0') }}'),
          StringStruct('InternalName', '{{ app_slug }}'),
          StringStruct('LegalCopyright', '© {{ maintainer_name }} — {{ license_spdx }}'),
          StringStruct('OriginalFilename', '{{ app_slug }}.exe'),
          StringStruct('ProductName', '{{ display_name }}'),
          StringStruct('ProductVersion', '{{ release_version | default('0.0.0') }}'),
        ],
      )
    ]),
    VarFileInfo([VarStruct('Translation', [1033, 1200])]),
  ],
)
