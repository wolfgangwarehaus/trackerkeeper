#!/usr/bin/env bash
# Build the Ubuntu/Debian .deb from the PyInstaller onedir bundle.
# GENERATED by `dough bake` from [tool.dough.metadata] — edit the template
# (packaging/templates/deb/build_deb.sh.j2), never this file.
#
# The bundle ships its own Python + PySide6 under /opt/{{ app_slug }}, so the
# package works on any apt distro new enough for the build runner's glibc (CI
# builds on ubuntu-22.04 → Ubuntu 22.04+/Debian 12+).
#
# PyInstaller bundles Qt but leaves a set of system libs to the host: we declare
# the COMPLETE Qt "xcb" platform-plugin closure explicitly as Depends so a clean
# (minimal) install still launches under X11/XWayland. (Wayland sessions use the
# bundled wayland plugin and need none of these, but we can't know the session at
# install time — so they're hard Depends.) A fork with extra native deps should
# add them here, or move to dpkg-shlibdeps auto-derivation (docs/BAKING.md §3.3).
#
# Usage (CI: .github/workflows/release.yml):
#   pyinstaller packaging/pyinstaller/{{ app_slug }}.spec --noconfirm
#   bash packaging/deb/build_deb.sh <version>
#
# Output: dist/{{ app_slug }}_<version>_amd64.deb

set -euo pipefail

VERSION="${1:?usage: build_deb.sh <version>}"
ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
BUNDLE="$ROOT/dist/{{ app_slug }}"
APP_ID="{{ app_id_base }}"

# Reproducible build: pin every timestamp to the commit so rebuilds are
# byte-identical (dpkg-deb clamps to SOURCE_DATE_EPOCH). Falls back to now.
: "${SOURCE_DATE_EPOCH:=$(git -C "$ROOT" log -1 --format=%ct 2>/dev/null || date +%s)}"
export SOURCE_DATE_EPOCH
STAGE="$(mktemp -d)"
trap 'rm -rf "$STAGE"' EXIT

[ -d "$BUNDLE" ] || { echo "PyInstaller bundle missing at $BUNDLE — build the spec first" >&2; exit 1; }

# ── payload ───────────────────────────────────────────────────────────
mkdir -p "$STAGE/opt"
cp -a "$BUNDLE" "$STAGE/opt/{{ app_slug }}"

mkdir -p "$STAGE/usr/bin"
ln -s "/opt/{{ app_slug }}/{{ app_slug }}" "$STAGE/usr/bin/{{ app_slug }}"

mkdir -p "$STAGE/usr/share/applications"
install -m644 "$ROOT/packaging/$APP_ID.desktop" "$STAGE/usr/share/applications/"

mkdir -p "$STAGE/usr/share/metainfo"
install -m644 "$ROOT/packaging/$APP_ID.metainfo.xml" "$STAGE/usr/share/metainfo/"

# Scalable SVG icon, named by the app-id (freedesktop icon lookup). A fork that
# wants a rasterized fallback adds hicolor/<size>x<size>/apps/$APP_ID.png too.
mkdir -p "$STAGE/usr/share/icons/hicolor/scalable/apps"
install -m644 "$ROOT/{{ icon_svg_source }}" \
    "$STAGE/usr/share/icons/hicolor/scalable/apps/$APP_ID.svg"

mkdir -p "$STAGE/usr/share/doc/{{ app_slug }}"
# DEP-5 machine-readable copyright (Policy references the license from
# /usr/share/common-licenses, which Debian/Ubuntu always ship).
cat > "$STAGE/usr/share/doc/{{ app_slug }}/copyright" <<EOF
Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/
Upstream-Name: {{ app_slug }}
Source: {{ homepage_url }}

Files: *
Copyright: 2026 {{ maintainer_name }} <{{ maintainer_email }}>
License: {{ license_spdx }}
{% if license_spdx in ("GPL-2.0-or-later", "GPL-2.0-only") %}
 This program is free software: you can redistribute it and/or modify it under
 the terms of the GNU General Public License as published by the Free Software
 Foundation, either version 2 of the License, or (at your option) any later
 version.
 .
 This program is distributed in the hope that it will be useful, but WITHOUT ANY
 WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS FOR A
 PARTICULAR PURPOSE.  See the GNU General Public License for more details.
 .
 On Debian systems, the complete text of the GNU General Public License version
 2 can be found in /usr/share/common-licenses/GPL-2.
{% else %}
 {{ display_name }} is licensed under {{ license_spdx }}; the full license text
 ships in the source tree (LICENSE) at {{ homepage_url }}.
{% endif %}
EOF
chmod 644 "$STAGE/usr/share/doc/{{ app_slug }}/copyright"

# Debian changelog (Policy-mandated; lintian warns no-changelog without it).
{
  echo "{{ app_slug }} ($VERSION) unstable; urgency=low"
  echo ""
  echo "  * Release $VERSION — see {{ releases_url }}"
  echo ""
  echo " -- {{ publisher_display_name }} <{{ maintainer_email }}>  $(date -u -R -d "@$SOURCE_DATE_EPOCH")"
} | gzip -9n > "$STAGE/usr/share/doc/{{ app_slug }}/changelog.Debian.gz"
chmod 644 "$STAGE/usr/share/doc/{{ app_slug }}/changelog.Debian.gz"

# ── control ───────────────────────────────────────────────────────────
INSTALLED_SIZE=$(du -ks "$STAGE" | cut -f1)
mkdir -p "$STAGE/DEBIAN"
cat > "$STAGE/DEBIAN/control" <<EOF
Package: {{ app_slug }}
Version: $VERSION
Architecture: amd64
Maintainer: {{ publisher_display_name }} <{{ maintainer_email }}>
Installed-Size: $INSTALLED_SIZE
Depends: libx11-6, libx11-xcb1, libxcb1, libxcb-cursor0, libxcb-icccm4, libxcb-image0, libxcb-keysyms1, libxcb-randr0, libxcb-render0, libxcb-render-util0, libxcb-shape0, libxcb-shm0, libxcb-sync1, libxcb-util1, libxcb-xfixes0, libxcb-xkb1, libxkbcommon0, libxkbcommon-x11-0, libfontconfig1, libfreetype6, libegl1, libgl1
Recommends: libnotify-bin
Section: devel
Priority: optional
Homepage: {{ homepage_url }}
Description: {{ summary }}
 {{ display_name }} — a self-contained desktop build.
 .
 Bundles Python and Qt under /opt/{{ app_slug }}; uses the system X/xcb +
 fontconfig stack for the Qt platform plugin.
EOF

# Maintainer scripts act per dpkg argument (Policy 6.5): refresh the icon cache +
# desktop database on install (configure) and removal (remove|purge).
cat > "$STAGE/DEBIAN/postinst" <<'EOF'
#!/bin/sh
set -e
case "$1" in
  configure)
    command -v gtk-update-icon-cache >/dev/null 2>&1 && gtk-update-icon-cache -q /usr/share/icons/hicolor || true
    command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database -q || true
    ;;
esac
EOF
chmod 755 "$STAGE/DEBIAN/postinst"

cat > "$STAGE/DEBIAN/postrm" <<'EOF'
#!/bin/sh
set -e
case "$1" in
  remove|purge)
    command -v gtk-update-icon-cache >/dev/null 2>&1 && gtk-update-icon-cache -q /usr/share/icons/hicolor || true
    command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database -q || true
    ;;
esac
EOF
chmod 755 "$STAGE/DEBIAN/postrm"

# ── build ─────────────────────────────────────────────────────────────
mkdir -p "$ROOT/dist"
OUT="$ROOT/dist/{{ app_slug }}_${VERSION}_amd64.deb"

# Normalize modes so the package doesn't inherit the build host's umask.
# Dirs → 0755; files → drop group/other write but KEEP the exec bit (the bundle
# has many executable .so/.bin files), so use `go-w` not a blanket 0644.
find "$STAGE" -type d -exec chmod 0755 {} +
find "$STAGE" -type f -exec chmod go-w {} +

dpkg-deb --build --root-owner-group -Zxz "$STAGE" "$OUT"
echo "built: $OUT"
