# Homebrew cask for {{ display_name }}. GENERATED by `dough bake` — the INITIAL
# cask to seed your tap (homebrew-<tap>); macos.yml's bump action maintains the
# version + sha256 thereafter (docs/BAKING.md §5). Committed form is version-free.
cask "{{ app_slug }}" do
  version "{{ release_version | default('0.0.0') }}"
  # universal2 → ONE fat .dmg serves both Apple Silicon and Intel, so a single
  # sha256 + url is correct. The per-arch fallback (a fork that ships two native
  # -macos-<arch>.dmg files) replaces these with on_arm/on_intel two-sha blocks
  # + two urls — see the spec's target_arch note.
{% if dmg_sha256 is defined and dmg_sha256 %}
  sha256 "{{ dmg_sha256 }}"
{% else %}
  sha256 :no_check
{% endif %}

  url "{{ releases_url }}/download/v#{version}/{{ app_slug }}-#{version}-macos.dmg"
  name "{{ display_name }}"
  desc "{{ summary }}"
  homepage "{{ homepage_url }}"

  app "{{ app_slug }}.app"

  zap trash: [
    "~/Library/Preferences/{{ cf_bundle_id }}.plist",
    "~/Library/Application Support/{{ display_name }}",
    "~/Library/Saved Application State/{{ cf_bundle_id }}.savedState",
  ]
end
