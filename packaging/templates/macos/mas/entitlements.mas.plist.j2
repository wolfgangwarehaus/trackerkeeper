<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  MAC APP STORE entitlements — the SANDBOXED build for {{ display_name }}.
  GENERATED by `dough bake` — edit the template
  (packaging/templates/macos/mas/entitlements.mas.plist.j2), never this file.

  DORMANT: signs the Mac App Store .pkg; unused until you enroll in the Apple
  Developer Program and add a build-mas CI job (docs/BAKING.md). SEPARATE from
  packaging/macos/entitlements.plist (the Developer-ID / notarized-.dmg build):

    .dmg (Developer ID)            .pkg (Mac App Store)
    - hardened runtime            - App Sandbox (mandatory)
    - disable-library-validation  - NO disable-library-validation (MAS rejects
      + allow-dyld-env-vars         it; re-sign every nested Mach-O with our own
                                    Team ID instead — see sign_mas.sh)

  The App Sandbox is deny-by-default; keep this set MINIMAL. app-sandbox is the
  only MANDATORY key — add capabilities only as your app actually needs them.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Outbound network — uncomment if your app talks to a server or API
         (the sandbox blocks every socket otherwise):
    <key>com.apple.security.network.client</key>
    <true/>
    -->
    <!-- application-identifier MUST match the provisioning profile or Apple
         rejects the upload (ITMS-90886). Signed onto the MAIN executable only
         (see sign_mas.sh). codesign substitutes $(AppIdentifierPrefix) and
         $(TeamIdentifierPrefix) from the embedded provisioning profile at sign
         time — NEVER hard-code a literal Team ID here. -->
    <key>com.apple.application-identifier</key>
    <string>$(AppIdentifierPrefix){{ cf_bundle_id }}</string>
    <key>com.apple.developer.team-identifier</key>
    <string>$(TeamIdentifierPrefix)</string>
</dict>
</plist>
