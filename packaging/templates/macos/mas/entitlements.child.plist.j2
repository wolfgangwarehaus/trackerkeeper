<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Child (nested-binary) entitlements for the sandboxed MAS build: every
     nested Mach-O is re-signed inside-out with app-sandbox + inherit, then the
     outer .app gets the full parent set (entitlements.mas.plist). -->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.inherit</key>
    <true/>
</dict>
</plist>
