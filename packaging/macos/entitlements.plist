<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Minimal Developer-ID (notarized, NON-sandbox .dmg) entitlements.
       PySide6 ships unsigned dylibs; relax library validation so the
       Developer-ID-signed .app loads them under the hardened runtime
       (docs/BAKING.md §5). allow-dyld-environment-variables lets the frozen
       app set the DYLD_* vars PyInstaller's bootloader relies on. GENERATED
       by `trackerkeeper bake`.

       Deliberately NOT present: com.apple.security.cs.allow-unsigned-executable-memory
       (the JIT/LuaJIT writable+executable-memory exception a media/mpv stack
       needs). trackerkeeper ships no such runtime — keep this set minimal; do not add
       it on a jellytoast sync. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
