<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-trust (packaged classic / "Desktop Bridge") MSIX manifest for dough.
  GENERATED by `dough bake` — edit the template, never this file.

  mediumIL + packagedClassicApp + runFullTrust -> NOT sandboxed: Win32 APIs (the
  frameless chrome, blur, single-instance, power-inhibit) work as in the Inno build.

  Publisher is the Partner-Center-issued CN (store_secrets_of_record.msix_publisher_cn)
  — blank until you register; the manual first submission fills it (docs/BAKING.md §9,
  packaging/msix/STORE-SUBMISSION.md). Version is a 4-part Store version DECOUPLED
  from the marketing version (first part must be != 0; bump it per submission).
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap10 desktop rescap">

  <Identity
      Name="wolfgangwarehaus.dough"
      Publisher="CN="
      Version="1.0.0.0"
      ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>dough</DisplayName>
    <PublisherDisplayName>wolfgang warehaus</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>A frosted, cross-platform PySide6 app base</Description>
  </Properties>

  <Dependencies>
    <!-- 1809 (17763) is the floor for uap10 packagedClassicApp full-trust. -->
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
        Id="dough"
        Executable="dough.exe"
        EntryPoint="Windows.FullTrustApplication"
        uap10:RuntimeBehavior="packagedClassicApp"
        uap10:TrustLevel="mediumIL">

      <uap:VisualElements
          DisplayName="dough"
          Description="A frosted, cross-platform PySide6 app base"
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Square71x71Logo="Assets\Square71x71Logo.png"
            Square310x310Logo="Assets\Square310x310Logo.png"
            Wide310x150Logo="Assets\Wide310x150Logo.png">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="transparent" />
      </uap:VisualElements>

      <Extensions>
        <!--
          Autostart for a packaged app MUST be a startupTask (Windows ignores the
          HKCU\...\Run key for packaged apps). Enabled="false" => off by default;
          the app flips it on via StartupTask.RequestEnableAsync(). dough's
          autostart backend uses this when is_msix_packaged() (docs/BAKING.md §5).
        -->
        <desktop:Extension
            Category="windows.startupTask"
            Executable="dough.exe"
            EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask
              TaskId="doughStartup"
              Enabled="false"
              DisplayName="dough" />
        </desktop:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Full Win32 trust — the RESTRICTED capability that triggers the manual
         Store review; justify it in Partner Center (STORE-SUBMISSION.md). -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
